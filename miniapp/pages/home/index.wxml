<view class="page">
  <block wx:if="{{loading}}">
    <view class="hero skeleton"></view>
    <view class="panel skeleton"></view>
  </block>

  <block wx:elif="{{error}}">
    <view class="hero">
      <text class="title">伊人Fashion 穿搭馆</text>
      <text class="subtitle">{{error}}</text>
      <button class="primary-button" bindtap="loadHome">重新加载</button>
    </view>
  </block>

  <block wx:elif="{{home}}">
    <view class="hero">
      <text class="eyebrow">STYLE SHOWROOM</text>
      <text class="title">{{home.shop_name || '伊人Fashion 穿搭馆'}}</text>
      <text class="subtitle">{{home.shop_intro || '分享轻时尚穿搭与日常灵感，欢迎浏览近期搭配记录，也可以直接联系我。'}}</text>
      <view class="hero-actions">
        <button class="primary-button" bindtap="goToProducts">查看穿搭</button>
        <button class="ghost-button" bindtap="goToContact">联系我</button>
      </view>
    </view>

    <swiper class="banner-swiper" indicator-dots="{{home.homepage_banner_urls.length > 1}}" autoplay="{{home.homepage_banner_urls.length > 1}}" circular="true">
      <block wx:for="{{home.homepage_banner_urls}}" wx:key="*this">
        <swiper-item>
          <image class="banner-image" src="{{item}}" mode="aspectFill"></image>
        </swiper-item>
      </block>
      <swiper-item wx:if="{{!home.homepage_banner_urls.length}}">
        <view class="banner-empty">封面图片将在这里显示</view>
      </swiper-item>
    </swiper>

    <view class="panel">
      <view class="panel-header">
        <text class="panel-title">近期分享</text>
        <text class="panel-caption">看看最近整理的穿搭内容</text>
      </view>
      <block wx:if="{{home.featured_products.length}}">
        <view class="product-list">
          <block wx:for="{{featuredColumns}}" wx:key="index" wx:for-item="column">
            <view class="product-column">
              <block wx:for="{{column}}" wx:key="id" wx:for-item="product">
                <view class="product-card" bindtap="goToProductDetail" data-product-id="{{product.id}}">
                  <image wx:if="{{product.cover_image_url}}" class="product-image" src="{{product.cover_image_url}}" mode="widthFix"></image>
                  <view wx:else class="product-image product-placeholder">暂无封面</view>
                  <view class="product-body">
                    <text class="product-name">{{product.name}}</text>
                    <view class="tag-row">
                      <text wx:for="{{product.tags}}" wx:key="*this" class="tag">{{item}}</text>
                    </view>
                  </view>
                </view>
              </block>
            </view>
          </block>
        </view>
      </block>
      <view wx:else class="empty-text">近期穿搭内容整理后会显示在这里</view>
    </view>
  </block>
</view>
