<view class="page">
  <block wx:if="{{loadingHome && !home}}">
    <view class="hero-card hero-card-skeleton skeleton"></view>
  </block>

  <block wx:elif="{{homeError && !home}}">
    <view class="hero-error">
      <text class="hero-error-title">伊人Fashion 穿搭馆</text>
      <text class="hero-error-subtitle">{{homeError}}</text>
      <button class="primary-button" bindtap="loadHome">重新加载</button>
    </view>
  </block>

  <block wx:elif="{{home}}">
    <view class="hero-stage">
      <view class="hero-card">
        <image
          wx:if="{{heroBannerUrl}}"
          class="hero-background"
          src="{{heroBannerUrl}}"
          mode="aspectFill"
        ></image>
        <view class="hero-backdrop {{heroBannerUrl ? 'hero-backdrop-with-image' : ''}}"></view>

        <view class="hero-summary hero-summary-compact">
          <view class="hero-meta-row">
            <text class="eyebrow">STYLE SHOWROOM</text>
            <text
              wx:if="{{heroBannerUrl}}"
              class="hero-preview-link"
              data-image-url="{{heroBannerUrl}}"
              bindtap="previewBanner"
            >查看封面</text>
          </view>
          <text class="hero-title">{{home.shop_name || '伊人Fashion 穿搭馆'}}</text>
          <text class="hero-subtitle">{{home.shop_intro || '分享轻时尚穿搭与日常灵感，欢迎直接下滑浏览穿搭，也可以给我留言。'}}</text>

          <view class="hero-actions hero-actions-right">
            <view class="hero-link-action" bindtap="goToContact">留言反馈</view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <view id="feed-section" class="panel feed-section">
    <view class="feed-meta-row">
      <text class="feed-meta-text">{{total ? ('已收录 ' + total + ' 套穿搭，可继续下滑浏览') : '下滑浏览更多穿搭内容'}}</text>
      <view wx:if="{{!showInlineSearch}}" class="feed-search-trigger" bindtap="openInlineSearch">
        <view class="feed-search-icon-circle"></view>
        <view class="feed-search-icon-handle"></view>
      </view>
    </view>

    <view wx:if="{{showInlineSearch}}" class="feed-search-inline">
      <input
        class="feed-search-input"
        placeholder="搜索风格 / 单品 / 关键词"
        confirm-type="search"
        focus="{{showInlineSearch}}"
        value="{{draftKeyword}}"
        bindinput="onKeywordInput"
        bindconfirm="submitSearch"
        bindblur="onInlineSearchBlur"
      />
    </view>

    <view wx:if="{{keyword}}" class="search-state-bar">
      <text class="search-state-label">搜索结果：{{keyword}}</text>
      <text class="search-state-clear" bindtap="clearSearch">清除</text>
    </view>

    <scroll-view wx:if="{{categories.length}}" class="category-strip" scroll-x enable-flex show-scrollbar="{{false}}">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-chip {{item.id === activeCategoryId ? 'category-chip-active' : ''}}"
        data-category-id="{{item.id}}"
        bindtap="selectCategory"
      >
        {{item.name}}
      </view>
    </scroll-view>

    <block wx:if="{{loadingProducts && !items.length}}">
      <view class="card skeleton"></view>
      <view class="card skeleton"></view>
    </block>

    <block wx:elif="{{productsError && !items.length}}">
      <view class="card empty-card">
        <text class="empty-title">{{productsError}}</text>
        <button class="primary-button" bindtap="reloadProducts">重新加载</button>
      </view>
    </block>

    <block wx:elif="{{items.length}}">
      <view class="list">
        <block wx:for="{{productColumns}}" wx:key="index" wx:for-item="column">
          <view class="product-column">
            <block wx:for="{{column}}" wx:key="id" wx:for-item="product">
              <view class="card product-card" bindtap="goToProductDetail" data-product-id="{{product.id}}">
                <image wx:if="{{product.cover_image_url}}" class="product-image" src="{{product.cover_image_url}}" mode="widthFix"></image>
                <view wx:else class="product-image product-placeholder">暂无封面</view>
                <view class="product-body">
                  <text class="product-name">{{product.name}}</text>
                  <view class="tag-row">
                    <text wx:for="{{product.tags}}" wx:key="*this" class="tag">{{item}}</text>
                  </view>
                </view>
              </view>
            </block>
          </view>
        </block>
      </view>
      <view class="footer-text">{{hasMore ? (loadingMore ? '加载更多中...' : '上滑继续查看') : '已经到底了'}}</view>
    </block>

    <block wx:else>
      <view class="card empty-card">
        <text class="empty-title">{{keyword ? '没有找到匹配的穿搭' : (activeCategoryId ? '当前分类下还没有相关穿搭' : '当前还没有可浏览的穿搭')}}</text>
        <text class="empty-subtitle">{{keyword ? '换个关键词，或者切换分类再试试' : (activeCategoryId ? '试试切换其他分类看看' : '整理完成后会在这里更新')}}</text>
      </view>
    </block>
  </view>
</view>
