<view class="page">
  <block wx:if="{{loading}}">
    <view class="hero skeleton"></view>
    <view class="panel skeleton"></view>
  </block>

  <block wx:elif="{{error}}">
    <view class="hero">
      <text class="title">伊人Fashion 穿搭馆</text>
      <text class="subtitle">{{error}}</text>
      <button class="primary-button" bindtap="loadHome">重新加载</button>
    </view>
  </block>

  <block wx:elif="{{home}}">
    <view class="hero">
      <text class="eyebrow">STYLE SHOWROOM</text>
      <text class="title">{{home.shop_name || '伊人Fashion 穿搭馆'}}</text>
      <text class="subtitle">{{home.shop_intro || '分享轻时尚女装搭配与穿搭灵感，欢迎到店体验或联系店主了解更多。'}}</text>
      <view class="hero-actions">
        <button class="primary-button" bindtap="goToProducts">查看穿搭</button>
        <button class="ghost-button" bindtap="goToContact">联系店主</button>
      </view>
    </view>

    <swiper class="banner-swiper" indicator-dots="{{home.homepage_banner_urls.length > 1}}" autoplay="{{home.homepage_banner_urls.length > 1}}" circular="true">
      <block wx:for="{{home.homepage_banner_urls}}" wx:key="*this">
        <swiper-item>
          <image class="banner-image" src="{{item}}" mode="aspectFill"></image>
        </swiper-item>
      </block>
      <swiper-item wx:if="{{!home.homepage_banner_urls.length}}">
        <view class="banner-empty">门店展示图将在后台配置后显示</view>
      </swiper-item>
    </swiper>

    <view class="panel">
      <view class="panel-header">
        <text class="panel-title">本周推荐</text>
        <text class="panel-caption">展示本店精选穿搭搭配</text>
      </view>
      <block wx:if="{{home.featured_products.length}}">
        <view class="product-list">
          <block wx:for="{{home.featured_products}}" wx:key="id">
            <view class="product-card" bindtap="goToProductDetail" data-product-id="{{item.id}}">
              <image wx:if="{{item.cover_image_url}}" class="product-image" src="{{item.cover_image_url}}" mode="aspectFill"></image>
              <view wx:else class="product-image product-placeholder">暂无封面</view>
              <view class="product-body">
                <text class="product-name">{{item.name}}</text>
                <view class="tag-row">
                  <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
                </view>
              </view>
            </view>
          </block>
        </view>
      </block>
      <view wx:else class="empty-text">门店推荐穿搭将在整理后显示</view>
    </view>
  </block>
</view>
