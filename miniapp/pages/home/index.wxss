.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 32rpx;
  background: linear-gradient(180deg, #f4f3f1 0%, #eceae7 100%);
}

.hero-stage {
  position: relative;
}

.hero-error {
  padding: 40rpx 36rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #1f1c1a 0%, #34302d 100%);
  color: #ffffff;
  box-shadow: 0 26rpx 46rpx rgba(35, 31, 28, 0.18);
}

.hero-error-title {
  display: block;
  font-size: 50rpx;
  font-weight: 700;
}

.hero-error-subtitle {
  display: block;
  margin-top: 18rpx;
  line-height: 1.8;
  color: rgba(255, 247, 240, 0.82);
}

.primary-button {
  background: #1f1c1a;
  color: #ffffff;
  font-weight: 600;
}

.primary-button::after,
.hero-chip::after {
  border: 0;
}

.hero-card {
  position: relative;
  min-height: 320rpx;
  border-radius: 36rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #f8f7f5 0%, #f1efec 100%);
  box-shadow: 0 22rpx 40rpx rgba(31, 28, 26, 0.12);
}

.hero-card-skeleton {
  height: 320rpx;
}

.hero-background {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-backdrop {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(252, 251, 249, 0.94) 0%, rgba(252, 251, 249, 0.98) 60%, rgba(252, 251, 249, 1) 100%);
}

.hero-backdrop-with-image {
  background: linear-gradient(180deg, rgba(252, 251, 249, 0.40) 0%, rgba(248, 246, 243, 0.78) 45%, rgba(251, 249, 247, 0.95) 100%);
}

.hero-summary {
  position: relative;
  margin: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.hero-summary-compact {
  min-height: 320rpx;
  padding: 28rpx 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.hero-meta-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-side-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.eyebrow {
  display: block;
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: #a7a29b;
}

.hero-preview-link {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #74706b;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(109, 85, 70, 0.1);
}

.hero-feedback-link {
  padding: 0 8rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #8b847d;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f1c1a;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  line-height: 1.7;
  color: #7a7671;
  font-size: 24rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.hero-actions {
  margin-top: 20rpx;
  min-height: 0;
}

.hero-actions-right {
  display: none;
}

.hero-chip {
  display: block;
  margin: 0;
  padding: 0 18rpx;
  width: 276rpx;
  max-width: calc(100% - 180rpx);
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 600;
}

.hero-chip-primary {
  background: #1f1c1a;
  color: #ffffff;
}


.panel {
  margin-top: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 32rpx rgba(31, 28, 26, 0.08);
}

.feed-section {
  margin-top: 22rpx;
}

.feed-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.feed-meta-text {
  flex: 1;
  min-width: 0;
  color: #99948e;
  font-size: 22rpx;
  line-height: 1.5;
}

.feed-search-trigger {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background: #f7f6f4;
  border: 1rpx solid rgba(24, 22, 20, 0.06);
  box-shadow: 0 6rpx 14rpx rgba(31, 28, 26, 0.04);
  flex-shrink: 0;
}

.feed-search-icon-circle {
  position: absolute;
  left: 18rpx;
  top: 16rpx;
  width: 16rpx;
  height: 16rpx;
  border: 3rpx solid #5e5954;
  border-radius: 50%;
}

.feed-search-icon-handle {
  position: absolute;
  right: 15rpx;
  bottom: 18rpx;
  width: 10rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #5e5954;
  transform: rotate(45deg);
  transform-origin: center;
}

.feed-search-inline {
  margin-top: 16rpx;
}

.feed-search-input {
  width: 100%;
  height: 68rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid rgba(24, 22, 20, 0.08);
  color: #1f1c1a;
  font-size: 24rpx;
  box-shadow: 0 10rpx 22rpx rgba(31, 28, 26, 0.05);
}

.search-state-bar {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.search-state-label {
  flex: 1;
  min-width: 0;
  color: #74706b;
  font-size: 22rpx;
  font-weight: 500;
}

.search-state-clear {
  flex-shrink: 0;
  color: #7a7671;
  font-size: 22rpx;
}

.category-strip {
  display: flex;
  white-space: nowrap;
  margin-top: 18rpx;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  margin-right: 14rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #7a7671;
  box-shadow: 0 8rpx 14rpx rgba(31, 28, 26, 0.05);
  font-size: 22rpx;
  font-weight: 500;
}

.category-chip-active {
  background: #1f1c1a;
  color: #ffffff;
}

.list {
  margin-top: 20rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.product-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.card {
  border-radius: 28rpx;
  background: #ffffff;
  overflow: hidden;
  box-shadow: 0 18rpx 28rpx rgba(31, 28, 26, 0.08);
}

.product-card {
  display: flex;
  flex-direction: column;
}

.product-image,
.product-placeholder {
  width: 100%;
}

.product-placeholder {
  min-height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #96918b;
  background: #f2f0ed;
}

.product-body {
  padding: 22rpx;
}

.product-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #272320;
}

.tag-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  background: #f1efec;
  color: #69645f;
  font-size: 22rpx;
}

.empty-card {
  margin-top: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #272320;
}

.empty-subtitle,
.footer-text {
  display: block;
  margin-top: 14rpx;
  color: #85807a;
  text-align: center;
}

.skeleton {
  animation: pulse 1.2s ease-in-out infinite;
  background: rgba(255, 255, 255, 0.74);
}

.card.skeleton {
  height: 420rpx;
  margin-top: 24rpx;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
