.page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #f9f3ec 0%, #efe6dc 100%);
}

.hero {
  padding: 40rpx 36rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #34231a 0%, #5a3c2f 100%);
  color: #fff7f0;
  box-shadow: 0 26rpx 46rpx rgba(52, 35, 26, 0.18);
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: rgba(255, 247, 240, 0.7);
}

.title {
  display: block;
  margin-top: 20rpx;
  font-size: 50rpx;
  font-weight: 700;
}

.subtitle {
  display: block;
  margin-top: 18rpx;
  line-height: 1.8;
  color: rgba(255, 247, 240, 0.82);
}

.hero-actions {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.primary-button {
  background: #f0d7bf;
  color: #382015;
  font-weight: 600;
}

.ghost-button {
  border: 1px solid rgba(240, 215, 191, 0.45);
  background: transparent;
  color: #fff7f0;
}

.banner-swiper {
  height: 320rpx;
  margin-top: 28rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.72);
}

.banner-image,
.banner-empty {
  width: 100%;
  height: 100%;
}

.banner-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9a7f6f;
  font-size: 26rpx;
}

.panel {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 18rpx 32rpx rgba(90, 60, 47, 0.08);
}

.panel-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #382015;
}

.panel-caption {
  font-size: 22rpx;
  color: #9a7f6f;
}

.product-list {
  margin-top: 20rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.product-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.product-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: #fff9f5;
  box-shadow: 0 14rpx 24rpx rgba(90, 60, 47, 0.08);
}

.product-image,
.product-placeholder {
  width: 100%;
}

.product-placeholder {
  min-height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a68b7a;
  background: #f3e8de;
}

.product-body {
  padding: 22rpx;
}

.product-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #352219;
}

.tag-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  background: #f1dfd1;
  color: #7a5947;
  font-size: 22rpx;
}

.empty-text {
  margin-top: 24rpx;
  color: #8f7362;
  text-align: center;
}

.skeleton {
  animation: pulse 1.2s ease-in-out infinite;
  background: rgba(255, 255, 255, 0.7);
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
