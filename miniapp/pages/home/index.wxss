.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: linear-gradient(180deg, #fffaf6 0%, #f7f2eb 100%);
}

.hero {
  padding: 40rpx 36rpx;
  border-radius: 32rpx;
  background: #2d221d;
  color: #fff8f2;
  box-shadow: 0 24rpx 40rpx rgba(45, 34, 29, 0.14);
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
}

.subtitle {
  display: block;
  margin-top: 18rpx;
  line-height: 1.7;
  color: rgba(255, 248, 242, 0.82);
}

.card {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
}

.label {
  display: block;
  color: #8a6d5c;
  font-size: 24rpx;
}

.value {
  display: block;
  margin-top: 12rpx;
  font-size: 36rpx;
  font-weight: 600;
}
