.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 32rpx;
  background: linear-gradient(180deg, #f9f3ec 0%, #efe6dc 100%);
}

.hero-stage {
  position: relative;
}

.hero-error {
  padding: 40rpx 36rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #34231a 0%, #5a3c2f 100%);
  color: #fff7f0;
  box-shadow: 0 26rpx 46rpx rgba(52, 35, 26, 0.18);
}

.hero-error-title {
  display: block;
  font-size: 50rpx;
  font-weight: 700;
}

.hero-error-subtitle {
  display: block;
  margin-top: 18rpx;
  line-height: 1.8;
  color: rgba(255, 247, 240, 0.82);
}

.primary-button {
  background: #3f2a1f;
  color: #fff8f2;
  font-weight: 600;
}

.primary-button::after,
.hero-chip::after {
  border: 0;
}

.hero-card {
  position: relative;
  min-height: 320rpx;
  border-radius: 36rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #fbf5ef 0%, #f3e7db 100%);
  box-shadow: 0 22rpx 40rpx rgba(90, 60, 47, 0.12);
}

.hero-card-skeleton {
  height: 320rpx;
}

.hero-background {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-backdrop {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255, 251, 247, 0.9) 0%, rgba(255, 248, 243, 0.98) 60%, rgba(255, 248, 243, 1) 100%);
}

.hero-backdrop-with-image {
  background: linear-gradient(180deg, rgba(255, 251, 247, 0.34) 0%, rgba(255, 248, 243, 0.72) 45%, rgba(255, 248, 243, 0.95) 100%);
}

.hero-summary {
  position: relative;
  margin: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.hero-summary-compact {
  min-height: 320rpx;
  padding: 28rpx 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.hero-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.eyebrow {
  display: block;
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: #a38a78;
}

.hero-preview-link {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #6d5546;
  background: rgba(255, 248, 243, 0.82);
  border: 1rpx solid rgba(109, 85, 70, 0.1);
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #382015;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  line-height: 1.7;
  color: #735b4d;
  font-size: 24rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.hero-actions {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.hero-chip {
  display: block;
  margin: 0;
  padding: 0 18rpx;
  width: 276rpx;
  max-width: calc(100% - 180rpx);
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 600;
}

.hero-chip-primary {
  background: #3e2a1f;
  color: #fff7f0;
}

.hero-link-action {
  flex-shrink: 0;
  margin-left: auto;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #7a5e4e;
  text-align: right;
}

.hero-search-inline {
  margin-top: 20rpx;
}

.hero-search-input {
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 243, 0.9);
  color: #3c271d;
  font-size: 24rpx;
}

.hero-search-input-full {
  width: 100%;
  box-sizing: border-box;
}

.panel {
  margin-top: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 18rpx 32rpx rgba(90, 60, 47, 0.08);
}

.feed-section {
  margin-top: 22rpx;
}

.feed-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.feed-meta-text {
  flex: 1;
  min-width: 0;
  color: #947969;
  font-size: 22rpx;
  line-height: 1.5;
}

.search-state-bar {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(244, 235, 226, 0.92);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.search-state-label {
  flex: 1;
  min-width: 0;
  color: #6d5546;
  font-size: 22rpx;
  font-weight: 500;
}

.search-state-clear {
  flex-shrink: 0;
  color: #7a5e4e;
  font-size: 22rpx;
}

.category-strip {
  display: flex;
  white-space: nowrap;
  margin-top: 18rpx;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  margin-right: 14rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #7a5e4e;
  box-shadow: 0 8rpx 14rpx rgba(90, 60, 47, 0.04);
  font-size: 22rpx;
  font-weight: 500;
}

.category-chip-active {
  background: #3f2a1f;
  color: #fff4ea;
}

.list {
  margin-top: 20rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.product-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  overflow: hidden;
  box-shadow: 0 18rpx 28rpx rgba(90, 60, 47, 0.08);
}

.product-card {
  display: flex;
  flex-direction: column;
}

.product-image,
.product-placeholder {
  width: 100%;
}

.product-placeholder {
  min-height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a68b7a;
  background: #f3e8de;
}

.product-body {
  padding: 22rpx;
}

.product-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #352219;
}

.tag-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  background: #f1dfd1;
  color: #7a5947;
  font-size: 22rpx;
}

.empty-card {
  margin-top: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #3d2a20;
}

.empty-subtitle,
.footer-text {
  display: block;
  margin-top: 14rpx;
  color: #8e7463;
  text-align: center;
}

.skeleton {
  animation: pulse 1.2s ease-in-out infinite;
  background: rgba(255, 255, 255, 0.7);
}

.card.skeleton {
  height: 420rpx;
  margin-top: 24rpx;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
