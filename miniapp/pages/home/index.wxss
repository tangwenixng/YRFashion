.page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #f9f3ec 0%, #efe6dc 100%);
}

.hero-stage {
  position: relative;
}

.hero-error {
  padding: 40rpx 36rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #34231a 0%, #5a3c2f 100%);
  color: #fff7f0;
  box-shadow: 0 26rpx 46rpx rgba(52, 35, 26, 0.18);
}

.hero-error-title {
  display: block;
  font-size: 50rpx;
  font-weight: 700;
}

.hero-error-subtitle {
  display: block;
  margin-top: 18rpx;
  line-height: 1.8;
  color: rgba(255, 247, 240, 0.82);
}

.primary-button {
  background: #f0d7bf;
  color: #382015;
  font-weight: 600;
}

.primary-button::after,
.hero-chip::after {
  border: 0;
}

.banner-swiper {
  height: 560rpx;
  border-radius: 40rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 30rpx 54rpx rgba(90, 60, 47, 0.14);
}

.banner-image,
.banner-empty {
  width: 100%;
  height: 100%;
}

.banner-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9a7f6f;
  font-size: 26rpx;
}

.hero-summary {
  position: relative;
  z-index: 1;
  margin: -84rpx 28rpx 0;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 250, 245, 0.94);
  box-shadow: 0 18rpx 34rpx rgba(90, 60, 47, 0.1);
}

.hero-summary-skeleton {
  min-height: 220rpx;
}

.eyebrow {
  display: block;
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: #a38a78;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #382015;
}

.hero-subtitle {
  display: block;
  margin-top: 14rpx;
  line-height: 1.7;
  color: #735b4d;
  font-size: 24rpx;
}

.hero-actions {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.hero-chip {
  margin: 0;
  padding: 0 26rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.hero-chip-primary {
  background: #3e2a1f;
  color: #fff7f0;
}

.hero-chip-secondary {
  background: rgba(240, 223, 209, 0.72);
  color: #6f5240;
}

.panel {
  margin-top: 32rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 18rpx 32rpx rgba(90, 60, 47, 0.08);
}

.panel-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #382015;
}

.panel-caption {
  font-size: 22rpx;
  color: #9a7f6f;
}

.product-list {
  margin-top: 20rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.product-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.product-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: #fff9f5;
  box-shadow: 0 14rpx 24rpx rgba(90, 60, 47, 0.08);
}

.product-image,
.product-placeholder {
  width: 100%;
}

.product-placeholder {
  min-height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a68b7a;
  background: #f3e8de;
}

.product-body {
  padding: 22rpx;
}

.product-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #352219;
}

.tag-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  background: #f1dfd1;
  color: #7a5947;
  font-size: 22rpx;
}

.empty-text {
  margin-top: 24rpx;
  color: #8f7362;
  text-align: center;
}

.skeleton {
  animation: pulse 1.2s ease-in-out infinite;
  background: rgba(255, 255, 255, 0.7);
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
