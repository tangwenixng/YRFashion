<view class="page">
  <view class="nav-shell" style="height: {{navBarTotalHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="nav-content" style="height: {{navBarHeight}}px;">
      <view class="nav-left">
        <view class="nav-icon-button" bindtap="goBack">
          <view class="nav-back-icon"></view>
        </view>
        <view class="nav-icon-button" bindtap="goHome">
          <view class="nav-home-icon">
            <view class="nav-home-roof"></view>
            <view class="nav-home-body"></view>
            <view class="nav-home-door"></view>
          </view>
        </view>
      </view>
      <text class="nav-title">{{navTitle}}</text>
      <view class="nav-right-space" style="width: {{navRightSpaceWidth}}px;"></view>
    </view>
  </view>
  <view class="nav-placeholder" style="height: {{navBarTotalHeight}}px;"></view>

  <view class="card intro-card">
    <text class="label">留言交流</text>
    <text class="title">{{productName || '当前穿搭'}}</text>
    <text class="hint">留言提交后会显示在记录中，我会在这里继续回复你。</text>
  </view>

  <view class="card profile-card">
    <view class="profile-header">
      <view>
        <text class="profile-title">留言身份</text>
        <text class="profile-hint">补充头像和昵称，方便在记录中识别你的留言内容。</text>
        <text wx:if="{{avatarReviewStatus === 'pending'}}" class="profile-status status-pending">
          当前头像审核中，审核通过后会显示在你的留言记录里。
        </text>
        <text wx:if="{{avatarReviewStatus === 'rejected'}}" class="profile-status status-rejected">
          当前头像未通过审核：{{avatarRejectReason || '请重新上传清晰、合规的头像'}}
        </text>
      </view>
      <text wx:if="{{needsProfileCompletion}}" class="profile-badge">首次留言需补充</text>
    </view>

    <view class="profile-row">
      <view class="avatar-column">
        <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar">
          <image wx:if="{{profileAvatarUrl}}" class="avatar-image" src="{{profileAvatarUrl}}" mode="aspectFill"></image>
          <view wx:else class="avatar-placeholder">
            <text class="avatar-placeholder-main">头像</text>
          </view>
        </button>
        <text class="avatar-tip">点击更换</text>
      </view>

      <view class="nickname-block {{nicknameFocused ? 'nickname-block-active' : ''}}">
        <input
          class="nickname-input"
          type="nickname"
          maxlength="100"
          placeholder="请输入昵称"
          value="{{profileNickname}}"
          bindinput="handleNicknameInput"
          bindfocus="handleNicknameFocus"
          bindblur="handleNicknameBlur"
        />
        <view class="nickname-hint-row">
          <text class="nickname-hint">留言记录中会显示这个昵称</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <textarea
      class="textarea"
      placeholder="请输入你想交流的内容，例如搭配想法、颜色偏好或穿着场景。"
      maxlength="{{maxLength}}"
      value="{{content}}"
      bindinput="handleInput"
    ></textarea>
    <view class="counter-row">
      <text class="counter">{{content.length}} / {{maxLength}}</text>
      <text class="counter-tip">请避免填写敏感隐私信息</text>
    </view>
  </view>

  <button class="submit-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitMessage">
    提交留言
  </button>
</view>
