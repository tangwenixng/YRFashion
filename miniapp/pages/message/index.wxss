@import "../../styles/custom-nav.wxss";

.page {
  min-height: 100vh;
  padding: 0 32rpx 32rpx;
  background: linear-gradient(180deg, #f4f3f1 0%, #eceae7 100%);
}

.card {
  padding: 30rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 28rpx rgba(31, 28, 26, 0.08);
  margin-top: 16rpx;
}

.intro-card {
  background: linear-gradient(135deg, #23201d 0%, #3a3532 100%);
  padding: 26rpx 32rpx 28rpx;
}

.label {
  display: block;
  color: rgba(250, 247, 244, 0.76);
  font-size: 22rpx;
}

.title {
  display: block;
  margin-top: 14rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.hint {
  display: block;
  margin-top: 16rpx;
  line-height: 1.8;
  color: rgba(250, 247, 244, 0.84);
}

.profile-header {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.profile-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #272320;
}

.profile-hint {
  display: block;
  margin-top: 8rpx;
  line-height: 1.7;
  color: #85807a;
  font-size: 22rpx;
}

.profile-status {
  display: block;
  margin-top: 10rpx;
  line-height: 1.7;
  font-size: 24rpx;
}

.status-pending {
  color: #7f766f;
}

.status-rejected {
  color: #bf4a38;
}

.profile-badge {
  flex-shrink: 0;
  height: fit-content;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(106, 98, 92, 0.12);
  color: #3a3532;
  font-size: 22rpx;
}

.profile-row {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-column {
  flex-shrink: 0;
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  overflow: hidden;
  background: transparent;
  line-height: 1;
}

.avatar-button::after {
  border: 0;
}

.avatar-image,
.avatar-placeholder {
  width: 104rpx;
  height: 104rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(98, 89, 83, 0.10);
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f1efec 0%, #dfdbd5 100%);
  color: #69645f;
  font-size: 24rpx;
  font-weight: 700;
}

.avatar-tip {
  margin-top: 10rpx;
  color: #9d9892;
  font-size: 20rpx;
  line-height: 1.5;
}

.nickname-block {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

.nickname-input {
  display: block;
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #f5f4f1;
  color: #272320;
  box-sizing: border-box;
  font-size: 26rpx;
  font-weight: 500;
  border: 2rpx solid transparent;
}

.nickname-block-active .nickname-input {
  border-color: rgba(98, 89, 83, 0.18);
  background: #f2f0ed;
}

.nickname-hint-row {
  margin-top: 10rpx;
  min-height: 30rpx;
  display: flex;
  align-items: flex-start;
}

.nickname-hint {
  display: block;
  color: #9d9892;
  font-size: 22rpx;
  line-height: 1.5;
}

.textarea {
  width: 100%;
  min-height: 320rpx;
  padding: 20rpx 24rpx;
  border-radius: 22rpx;
  background: #f5f4f1;
  line-height: 1.8;
  color: #272320;
  box-sizing: border-box;
}

.counter-row {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  color: #85807a;
  font-size: 22rpx;
}

.submit-button {
  margin-top: 28rpx;
  width: 100%;
  background: #1f1c1a;
  color: #ffffff;
}

.submit-button::after {
  border: 0;
}

@media (max-width: 520px) {
  .profile-row {
    gap: 18rpx;
  }

  .avatar-column {
    width: 92rpx;
    height: 92rpx;
  }

  .avatar-button,
  .avatar-image,
  .avatar-placeholder {
    width: 92rpx;
    height: 92rpx;
  }
}
