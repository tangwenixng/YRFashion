<view class="page">
  <view class="nav-shell" style="height: {{navBarTotalHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="nav-content" style="height: {{navBarHeight}}px;">
      <view class="nav-left">
        <view class="nav-icon-button" bindtap="goBack">
          <view class="nav-back-icon"></view>
        </view>
        <view class="nav-icon-button" bindtap="goHome">
          <view class="nav-home-icon">
            <view class="nav-home-roof"></view>
            <view class="nav-home-body"></view>
            <view class="nav-home-door"></view>
          </view>
        </view>
      </view>
      <text class="nav-title">{{navTitle}}</text>
      <view class="nav-right-space" style="width: {{navRightSpaceWidth}}px;"></view>
    </view>
  </view>
  <view class="nav-placeholder" style="height: {{navBarTotalHeight}}px;"></view>

  <block wx:if="{{loading}}">
    <view class="card skeleton"></view>
    <view class="card skeleton"></view>
  </block>

  <block wx:elif="{{error}}">
    <view class="card error-card">
      <text class="shop-name">联系我</text>
      <text class="field-value">{{error}}</text>
      <button class="action-button secondary" bindtap="loadContact">重新加载</button>
    </view>
  </block>

  <block wx:elif="{{contact}}">
    <view class="card intro-card">
      <view class="intro-head">
        <text class="label label-light">CONTACT</text>
        <text class="intro-badge">轻松交流</text>
      </view>
      <text class="shop-name">{{contact.shop_name || '伊人Fashion 穿搭馆'}}</text>
      <text class="field-value">欢迎通过电话或微信联系我。看到消息后，我会尽快回复你。</text>
    </view>

    <view class="card contact-card">
      <view class="contact-row">
        <view class="contact-copy">
          <text class="field-label">联系电话</text>
          <text class="field-value">{{contact.contact_phone || '暂未设置'}}</text>
        </view>
        <button class="mini-action" bindtap="handleCall">拨打</button>
      </view>
    </view>

    <view class="card contact-card">
      <view class="contact-row">
        <view class="contact-copy">
          <text class="field-label">微信号</text>
          <text class="field-value">{{contact.wechat_id || '暂未设置'}}</text>
        </view>
        <button class="mini-action mini-action-secondary" bindtap="handleCopyWechat">复制</button>
      </view>
    </view>

    <view class="card info-grid">
      <view class="info-tile">
        <text class="field-label">所在地区</text>
        <text class="field-value">{{contact.address || '暂未设置'}}</text>
      </view>
      <view class="info-tile">
        <text class="field-label">回复时段</text>
        <text class="field-value">{{contact.business_hours || '暂未设置'}}</text>
      </view>
    </view>

    <view class="page-footer" bindtap="handleConsoleEntryTap">
      <text class="footer-text">YRFashion</text>
    </view>
  </block>
</view>
