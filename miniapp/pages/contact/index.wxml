<view class="page">
  <block wx:if="{{loading}}">
    <view class="card skeleton"></view>
    <view class="card skeleton"></view>
  </block>

  <block wx:elif="{{error}}">
    <view class="card error-card">
      <text class="shop-name">Contact</text>
      <text class="field-value">{{error}}</text>
      <button class="action-button secondary" bindtap="loadContact">Reload</button>
    </view>
  </block>

  <block wx:elif="{{contact}}">
    <view class="card intro-card">
      <text class="label">Store</text>
      <text class="shop-name">{{contact.shop_name || 'YRFasion'}}</text>
      <text class="field-value">Reach the owner by phone or WeChat.</text>
    </view>

    <view class="card">
      <view class="field-row">
        <text class="field-label">Phone</text>
        <text class="field-value">{{contact.contact_phone || 'Not set'}}</text>
      </view>
      <button class="action-button" bindtap="handleCall">Call</button>
    </view>

    <view class="card">
      <view class="field-row">
        <text class="field-label">WeChat</text>
        <text class="field-value">{{contact.wechat_id || 'Not set'}}</text>
      </view>
      <button class="action-button secondary" bindtap="handleCopyWechat">Copy WeChat ID</button>
    </view>

    <view class="card info-grid">
      <view>
        <text class="field-label">Address</text>
        <text class="field-value">{{contact.address || 'Not set'}}</text>
      </view>
      <view>
        <text class="field-label">Business Hours</text>
        <text class="field-value">{{contact.business_hours || 'Not set'}}</text>
      </view>
    </view>

    <view class="card admin-entry-card">
      <text class="field-label">Admin Entry</text>
      <text class="field-value">Store staff can open the mobile admin from here.</text>
      <button class="action-button secondary admin-entry-button" bindtap="goToAdminLogin">Open Admin</button>
    </view>
  </block>
</view>
