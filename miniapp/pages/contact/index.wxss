@import "../../styles/custom-nav.wxss";

.page {
  min-height: 100vh;
  padding: 0 32rpx 32rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 243, 232, 0.92) 0%, rgba(255, 243, 232, 0) 34%),
    linear-gradient(180deg, #faf4ee 0%, #eee2d6 100%);
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 34rpx rgba(98, 68, 52, 0.08);
}

.intro-card {
  background:
    linear-gradient(135deg, rgba(74, 48, 34, 0.96) 0%, rgba(122, 86, 64, 0.92) 100%);
  color: #fff8f2;
}

.intro-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.label,
.field-label {
  display: block;
  color: #9a7f6f;
  font-size: 22rpx;
}

.label-light {
  color: rgba(255, 248, 242, 0.62);
  letter-spacing: 4rpx;
}

.intro-badge {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 242, 0.14);
  color: rgba(255, 248, 242, 0.88);
  font-size: 22rpx;
}

.intro-card .label,
.intro-card .field-value {
  color: rgba(255, 248, 242, 0.82);
}

.shop-name {
  display: block;
  margin-top: 18rpx;
  font-size: 46rpx;
  font-weight: 700;
}

.field-value {
  display: block;
  margin-top: 8rpx;
  line-height: 1.7;
  color: #3f2a1f;
  font-size: 29rpx;
}

.contact-card {
  padding-top: 26rpx;
  padding-bottom: 26rpx;
}

.contact-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.contact-copy {
  flex: 1;
  min-width: 0;
}

.action-button {
  margin-top: 22rpx;
  background: #3f2a1f;
  color: #fff8f2;
}

.action-button.secondary {
  background: #ebd7c4;
  color: #4a3022;
}

.mini-action {
  margin: 0;
  min-width: 132rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #3f2a1f;
  color: #fff8f2;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.mini-action::after,
.action-button::after {
  border: 0;
}

.mini-action-secondary {
  background: #efe0cf;
  color: #5d4333;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
}

.info-tile {
  min-height: 168rpx;
  padding: 6rpx 2rpx;
}

.page-footer {
  display: flex;
  justify-content: center;
  padding: 20rpx 0 8rpx;
}

.footer-text {
  color: rgba(74, 48, 34, 0.28);
  font-size: 20rpx;
  letter-spacing: 4rpx;
}

.error-card {
  text-align: center;
}

.skeleton {
  height: 220rpx;
  animation: pulse 1.2s ease-in-out infinite;
}

@media (max-width: 520px) {
  .info-grid {
    grid-template-columns: 1fr;
  }

  .contact-row {
    align-items: flex-start;
    flex-direction: column;
  }
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
