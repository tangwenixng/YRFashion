@import "../../styles/custom-nav.wxss";

.page {
  min-height: 100vh;
  padding: 0 32rpx 32rpx;
  background:
    radial-gradient(circle at top right, rgba(246, 244, 241, 0.88) 0%, rgba(243, 239, 234, 0) 34%),
    linear-gradient(180deg, #f6f5f3 0%, #ebe9e6 100%);
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(31, 28, 26, 0.08);
}

.intro-card {
  background:
    linear-gradient(135deg, rgba(36, 31, 28, 0.96) 0%, rgba(63, 56, 51, 0.92) 100%);
  color: #ffffff;
}

.intro-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.label,
.field-label {
  display: block;
  color: #9d9892;
  font-size: 22rpx;
}

.label-light {
  color: rgba(250, 247, 244, 0.64);
  letter-spacing: 4rpx;
}

.intro-badge {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(250, 247, 244, 0.14);
  color: rgba(250, 247, 244, 0.88);
  font-size: 22rpx;
}

.intro-card .label,
.intro-card .field-value {
  color: rgba(250, 247, 244, 0.84);
}

.shop-name {
  display: block;
  margin-top: 18rpx;
  font-size: 46rpx;
  font-weight: 700;
}

.field-value {
  display: block;
  margin-top: 8rpx;
  line-height: 1.7;
  color: #1f1c1a;
  font-size: 29rpx;
}

.feedback-card {
  padding-top: 26rpx;
  padding-bottom: 24rpx;
}

.feedback-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.feedback-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f1ee;
  color: #69645f;
  font-size: 22rpx;
}

.action-button {
  margin-top: 22rpx;
  background: #1f1c1a;
  color: #ffffff;
}

.action-button.secondary {
  background: #ece9e4;
  color: #23201d;
}

.mini-action {
  margin: 0;
  min-width: 176rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #1f1c1a;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.mini-action::after,
.action-button::after {
  border: 0;
}

.feedback-actions {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.feedback-link {
  color: #85807a;
  font-size: 24rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
}

.info-tile {
  min-height: 168rpx;
  padding: 6rpx 2rpx;
}

.page-footer {
  display: flex;
  justify-content: center;
  padding: 20rpx 0 8rpx;
}

.footer-text {
  color: rgba(63, 56, 51, 0.26);
  font-size: 20rpx;
  letter-spacing: 4rpx;
}

.error-card {
  text-align: center;
}

.skeleton {
  height: 220rpx;
  animation: pulse 1.2s ease-in-out infinite;
}

@media (max-width: 520px) {
  .info-grid {
    grid-template-columns: 1fr;
  }

  .feedback-head,
  .feedback-actions {
    align-items: flex-start;
    flex-direction: column;
  }
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
