.page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #f7efe8 0%, #efe3d8 100%);
}

.card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 18rpx 28rpx rgba(98, 68, 52, 0.08);
}

.intro-card {
  background: linear-gradient(135deg, #4a3022 0%, #7a5640 100%);
  color: #fff8f2;
}

.label,
.field-label {
  display: block;
  color: #9a7f6f;
  font-size: 22rpx;
}

.intro-card .label,
.intro-card .field-value {
  color: rgba(255, 248, 242, 0.82);
}

.shop-name {
  display: block;
  margin-top: 16rpx;
  font-size: 42rpx;
  font-weight: 700;
}

.field-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field-value {
  display: block;
  margin-top: 10rpx;
  line-height: 1.8;
  color: #3f2a1f;
  font-size: 28rpx;
}

.action-button {
  margin-top: 22rpx;
  background: #3f2a1f;
  color: #fff8f2;
}

.action-button.secondary {
  background: #ebd7c4;
  color: #4a3022;
}

.info-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.admin-entry-card {
  border: 1rpx dashed rgba(98, 68, 52, 0.18);
}

.admin-entry-button {
  margin-top: 18rpx;
}

.error-card {
  text-align: center;
}

.skeleton {
  height: 220rpx;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
