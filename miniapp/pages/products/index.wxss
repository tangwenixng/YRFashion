@import "../../styles/custom-nav.wxss";

.page {
  min-height: 100vh;
  padding: 0 32rpx 32rpx;
  background: linear-gradient(180deg, #f4f3f1 0%, #eceae7 100%);
}

.card {
  border-radius: 28rpx;
  background: #ffffff;
  overflow: hidden;
  box-shadow: 0 18rpx 28rpx rgba(31, 28, 26, 0.08);
}

.category-panel {
  margin-top: 8rpx;
}

.category-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  max-width: 100%;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #7a7671;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.4;
  box-shadow: 0 8rpx 14rpx rgba(31, 28, 26, 0.05);
}

.category-chip-active {
  background: #1f1c1a;
  color: #ffffff;
}

.category-chip-skeleton {
  min-width: 160rpx;
  min-height: 56rpx;
}

.result-header {
  margin-top: 26rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.result-title {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f1c1a;
}

.result-reset {
  flex-shrink: 0;
  color: #7a7671;
  font-size: 22rpx;
  line-height: 1.4;
}

.list {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.product-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.product-card {
  display: flex;
  flex-direction: column;
}

.cover,
.cover-placeholder {
  width: 100%;
}

.cover-placeholder {
  min-height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f2f0ed;
  color: #96918b;
}

.content {
  padding: 24rpx;
}

.product-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #272320;
}

.tag-row {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  background: #f1efec;
  color: #69645f;
  font-size: 22rpx;
}

.empty-card {
  padding: 48rpx 32rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #272320;
}

.empty-subtitle,
.footer-text {
  display: block;
  margin-top: 14rpx;
  color: #85807a;
  text-align: center;
  line-height: 1.6;
}

.primary-button {
  margin-top: 24rpx;
  background: #1f1c1a;
  color: #ffffff;
}

.result-skeleton,
.skeleton {
  animation: pulse 1.2s ease-in-out infinite;
}

.result-skeleton {
  height: 420rpx;
  margin-bottom: 22rpx;
}

.skeleton {
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
