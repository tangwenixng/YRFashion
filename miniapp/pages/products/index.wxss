@import "../../styles/custom-nav.wxss";

.page {
  min-height: 100vh;
  padding: 0 32rpx 32rpx;
  background: linear-gradient(180deg, #f4f3f1 0%, #eceae7 100%);
}

.page-header {
  margin-bottom: 24rpx;
}

.search-bar {
  margin-bottom: 22rpx;
}

.search-inline {
  margin-top: 16rpx;
}

.search-input {
  width: 100%;
  height: 68rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid rgba(24, 22, 20, 0.08);
  color: #1f1c1a;
  font-size: 24rpx;
  box-shadow: 0 10rpx 22rpx rgba(31, 28, 26, 0.05);
}

.search-state-bar {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.search-reset {
  flex-shrink: 0;
  color: #7a7671;
  font-size: 22rpx;
  line-height: 1.4;
}

.category-strip {
  display: flex;
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  margin-right: 14rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #7a7671;
  box-shadow: 0 8rpx 14rpx rgba(31, 28, 26, 0.05);
  font-size: 22rpx;
  font-weight: 500;
}

.category-chip-active {
  background: #1f1c1a;
  color: #ffffff;
}

.title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  color: #1f1c1a;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #85807a;
}

.list {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.product-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.card {
  border-radius: 28rpx;
  background: #ffffff;
  overflow: hidden;
  box-shadow: 0 18rpx 28rpx rgba(31, 28, 26, 0.08);
}

.product-card {
  display: flex;
  flex-direction: column;
}

.cover,
.cover-placeholder {
  width: 100%;
}

.cover-placeholder {
  min-height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f2f0ed;
  color: #96918b;
}

.content {
  padding: 24rpx;
}

.product-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #272320;
}

.tag-row {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  background: #f1efec;
  color: #69645f;
  font-size: 22rpx;
}

.empty-card {
  padding: 48rpx 32rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #272320;
}

.empty-subtitle,
.footer-text {
  display: block;
  margin-top: 14rpx;
  color: #85807a;
  text-align: center;
}

.primary-button {
  margin-top: 24rpx;
  background: #1f1c1a;
  color: #ffffff;
}

.skeleton {
  height: 420rpx;
  margin-bottom: 22rpx;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
