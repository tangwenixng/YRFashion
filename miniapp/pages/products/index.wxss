.page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #fcf7f1 0%, #efe6dc 100%);
}

.page-header {
  margin-bottom: 24rpx;
}

.search-bar {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.search-shell {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 12rpx 20rpx rgba(90, 60, 47, 0.06);
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(248, 242, 234, 0.86);
  color: #3c271d;
  font-size: 26rpx;
}

.search-button {
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: #efe1d3;
  border: 2rpx solid rgba(111, 82, 64, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.search-button-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.search-icon-circle {
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid #6f5240;
  border-radius: 50%;
}

.search-icon-handle {
  position: absolute;
  right: 0;
  bottom: 2rpx;
  width: 10rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #6f5240;
  transform: rotate(45deg);
  transform-origin: center;
}

.search-reset {
  align-self: flex-end;
  padding-right: 12rpx;
  color: #7a5e4e;
  font-size: 22rpx;
}

.category-strip {
  display: flex;
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  margin-right: 14rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #7a5e4e;
  box-shadow: 0 8rpx 14rpx rgba(90, 60, 47, 0.04);
  font-size: 22rpx;
  font-weight: 500;
}

.category-chip-active {
  background: #3f2a1f;
  color: #fff4ea;
}

.title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  color: #352219;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #8c6d5c;
}

.list {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.product-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  overflow: hidden;
  box-shadow: 0 18rpx 28rpx rgba(90, 60, 47, 0.08);
}

.product-card {
  display: flex;
  flex-direction: column;
}

.cover,
.cover-placeholder {
  width: 100%;
}

.cover-placeholder {
  min-height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1e4d7;
  color: #937868;
}

.content {
  padding: 24rpx;
}

.product-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #37231a;
}

.tag-row {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  background: #f2dfd1;
  color: #7b5a49;
  font-size: 22rpx;
}

.empty-card {
  padding: 48rpx 32rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #3d2a20;
}

.empty-subtitle,
.footer-text {
  display: block;
  margin-top: 14rpx;
  color: #8e7463;
  text-align: center;
}

.primary-button {
  margin-top: 24rpx;
  background: #3f2a1f;
  color: #fff8f2;
}

.skeleton {
  height: 420rpx;
  margin-bottom: 22rpx;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
