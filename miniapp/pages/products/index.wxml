<view class="page">
  <view class="nav-shell" style="height: {{navBarTotalHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="nav-content" style="height: {{navBarHeight}}px;">
      <view class="nav-left">
        <view class="nav-icon-button" bindtap="goBack">
          <view class="nav-back-icon"></view>
        </view>
        <view class="nav-icon-button" bindtap="goHome">
          <view class="nav-home-icon">
            <view class="nav-home-roof"></view>
            <view class="nav-home-body"></view>
            <view class="nav-home-door"></view>
          </view>
        </view>
      </view>
      <text class="nav-title">{{navTitle}}</text>
      <view class="nav-right-space" style="width: {{navRightSpaceWidth}}px;"></view>
    </view>
  </view>
  <view class="nav-placeholder" style="height: {{navBarTotalHeight}}px;"></view>

  <view class="category-panel">
    <block wx:if="{{loadingCategories}}">
      <view class="category-grid">
        <view class="category-option skeleton category-option-skeleton" wx:for="{{[0, 1, 2, 3, 4, 5]}}" wx:key="*this"></view>
      </view>
    </block>

    <view wx:else class="category-grid">
      <view
        wx:for="{{visibleCategories}}"
        wx:key="id"
        class="category-option {{item.id === activeCategoryId ? 'category-option-active' : ''}}"
        data-category-id="{{item.id}}"
        data-category-name="{{item.name}}"
        bindtap="selectCategory"
      >
        <text class="category-option-name">{{item.name}}</text>
      </view>
    </view>

    <view wx:if="{{categoryToggleVisible}}" class="category-toggle" bindtap="toggleCategoryExpand">
      <text class="category-toggle-text">{{isCategoryExpanded ? '收起' : '展开更多'}}</text>
      <text class="category-toggle-arrow {{isCategoryExpanded ? 'category-toggle-arrow-up' : ''}}">⌄</text>
    </view>
  </view>

  <view class="result-header">
    <text class="result-title">{{hasSelectedCategory ? activeCategoryName : '精选穿搭'}}</text>
    <block wx:if="{{hasSelectedCategory}}">
      <text class="result-reset" bindtap="clearSelection">重新选分类</text>
    </block>
  </view>

  <block wx:if="{{loading && !items.length}}">
    <view class="card skeleton result-skeleton"></view>
    <view class="card skeleton result-skeleton"></view>
  </block>

  <block wx:elif="{{error && !items.length}}">
    <view class="card empty-card">
      <text class="empty-title">{{error}}</text>
      <button class="primary-button" bindtap="reloadProducts">重新加载</button>
    </view>
  </block>

  <block wx:elif="{{items.length}}">
    <view class="list">
      <block wx:for="{{productColumns}}" wx:key="index" wx:for-item="column">
        <view class="product-column">
          <block wx:for="{{column}}" wx:key="id" wx:for-item="product">
            <view class="card product-card" bindtap="goToDetail" data-product-id="{{product.id}}">
              <image wx:if="{{product.cover_image_url}}" class="cover" src="{{product.cover_image_url}}" mode="widthFix"></image>
              <view wx:else class="cover cover-placeholder">暂无封面</view>
              <view class="content">
                <text class="product-name">{{product.name}}</text>
                <view class="tag-row">
                  <text wx:for="{{product.tags}}" wx:key="*this" class="tag">{{item}}</text>
                </view>
              </view>
            </view>
          </block>
        </view>
      </block>
    </view>
    <view wx:if="{{hasSelectedCategory}}" class="footer-text">{{hasMore ? (loadingMore ? '加载更多中...' : '上滑继续查看') : '已经到底了'}}</view>
  </block>

  <block wx:else>
    <view class="card empty-card">
      <text class="empty-title">暂无内容</text>
    </view>
  </block>
</view>
