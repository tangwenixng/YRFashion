<view class="page">
  <view class="page-header">
    <text class="title">穿搭展示</text>
    <text class="subtitle">展示本店精选穿搭搭配</text>
  </view>

  <block wx:if="{{loading}}">
    <view class="card skeleton"></view>
    <view class="card skeleton"></view>
  </block>

  <block wx:elif="{{error && !items.length}}">
    <view class="card empty-card">
      <text class="empty-title">{{error}}</text>
      <button class="primary-button" bindtap="reloadProducts">重新加载</button>
    </view>
  </block>

  <block wx:elif="{{items.length}}">
    <view class="list">
      <block wx:for="{{items}}" wx:key="id">
        <view class="card product-card" bindtap="goToDetail" data-product-id="{{item.id}}">
          <image wx:if="{{item.cover_image_url}}" class="cover" src="{{item.cover_image_url}}" mode="aspectFill"></image>
          <view wx:else class="cover cover-placeholder">暂无封面</view>
          <view class="content">
            <text class="product-name">{{item.name}}</text>
            <view class="tag-row">
              <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>
    <view class="footer-text">{{hasMore ? (loadingMore ? '加载更多中...' : '上滑继续查看') : '已经到底了'}}</view>
  </block>

  <block wx:else>
    <view class="card empty-card">
      <text class="empty-title">当前还没有可展示的穿搭</text>
      <text class="empty-subtitle">店主整理完成后会在这里展示</text>
    </view>
  </block>
</view>
