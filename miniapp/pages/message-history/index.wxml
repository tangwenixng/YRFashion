<view class="page">
  <view class="page-header">
    <text class="title">留言记录</text>
    <text class="subtitle">{{productName ? ('当前筛选：' + productName) : '查看你提交过的留言内容和回复'}}</text>
  </view>

  <block wx:if="{{loading}}">
    <view class="card skeleton"></view>
    <view class="card skeleton"></view>
  </block>

  <block wx:elif="{{error}}">
    <view class="card empty-card">
      <text class="empty-title">{{error}}</text>
      <button class="primary-button" bindtap="reloadMessages">重新加载</button>
    </view>
  </block>

  <block wx:elif="{{items.length}}">
    <view class="history-list">
      <view wx:for="{{items}}" wx:key="id" class="card history-item">
        <view class="history-head">
          <view>
            <text class="product-name">{{item.product_name}}</text>
            <text class="time-text">{{item.created_at_text}}</text>
          </view>
          <text class="history-status history-status-{{item.status_tone}}">{{item.status_label}}</text>
        </view>

        <text class="history-content">{{item.content}}</text>

        <view wx:if="{{item.reply_content}}" class="reply-card">
          <view class="reply-head">
            <text class="reply-title">我的回复</text>
            <text class="reply-time">{{item.reply_at_text}}</text>
          </view>
          <text class="reply-content">{{item.reply_content}}</text>
        </view>

        <button class="link-button" data-product-id="{{item.product_id}}" bindtap="goToDetail">查看对应穿搭</button>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="card empty-card">
      <text class="empty-title">你还没有提交过留言</text>
      <text class="empty-subtitle">可以先去看看穿搭内容，找到感兴趣的搭配再留言交流。</text>
    </view>
  </block>
</view>
