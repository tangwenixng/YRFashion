@import "../../styles/custom-nav.wxss";

.page {
  min-height: 100vh;
  padding: 0 32rpx 32rpx;
  background: linear-gradient(180deg, #f4f3f1 0%, #eceae7 100%);
}

.page-header {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1f1c1a;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  color: #85807a;
  line-height: 1.7;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 28rpx rgba(31, 28, 26, 0.08);
}

.history-item,
.empty-card {
  padding: 30rpx;
}

.history-head,
.reply-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.product-name,
.reply-title,
.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #272320;
}

.time-text,
.reply-time,
.empty-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #85807a;
  line-height: 1.7;
}

.history-status {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.history-status-pending {
  background: #f3f1ee;
  color: #7a7671;
}

.history-status-read {
  background: #f3f2ef;
  color: #76716c;
}

.history-status-replied {
  background: #1f1c1a;
  color: #ffffff;
}

.history-content,
.reply-content {
  display: block;
  margin-top: 18rpx;
  color: #37312d;
  line-height: 1.9;
}

.reply-card {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f5f4f1;
  border-left: 8rpx solid #1f1c1a;
}

.link-button,
.primary-button {
  margin-top: 22rpx;
  background: #1f1c1a;
  color: #ffffff;
}

.skeleton {
  height: 280rpx;
  margin-bottom: 20rpx;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
