@import "../../styles/custom-nav.wxss";

.page {
  min-height: 100vh;
  padding: 0 32rpx 32rpx;
  background: linear-gradient(180deg, #fcf7f1 0%, #efe6dc 100%);
}

.page-header {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #352219;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  color: #8c6d5c;
  line-height: 1.7;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 28rpx rgba(90, 60, 47, 0.08);
}

.history-item,
.empty-card {
  padding: 30rpx;
}

.history-head,
.reply-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.product-name,
.reply-title,
.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #3d2a20;
}

.time-text,
.reply-time,
.empty-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #8e7463;
  line-height: 1.7;
}

.history-status {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.history-status-pending {
  background: #f3e1d2;
  color: #80593f;
}

.history-status-read {
  background: #eee8df;
  color: #6f655d;
}

.history-status-replied {
  background: #3f2a1f;
  color: #fff7f0;
}

.history-content,
.reply-content {
  display: block;
  margin-top: 18rpx;
  color: #493327;
  line-height: 1.9;
}

.reply-card {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f8f1ea;
  border-left: 8rpx solid #3f2a1f;
}

.link-button,
.primary-button {
  margin-top: 22rpx;
  background: #3f2a1f;
  color: #fff8f2;
}

.skeleton {
  height: 280rpx;
  margin-bottom: 20rpx;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
