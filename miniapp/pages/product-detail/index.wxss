@import "../../styles/custom-nav.wxss";

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background: linear-gradient(180deg, #fcf7f1 0%, #eee3d6 100%);
}

.hero-wrap {
  position: relative;
  background: #f6efe7;
}

.hero {
  width: 100%;
  min-height: 720rpx;
  background: rgba(255, 255, 255, 0.65);
}

.hero-image,
.hero-placeholder {
  width: 100%;
  height: 100%;
}

.hero-image {
  background: #f6efe7;
}

.hero-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8f7463;
}

.hero-dots {
  position: absolute;
  left: 50%;
  bottom: 24rpx;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(34, 24, 18, 0.22);
}

.hero-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.55);
  transition: all 0.2s ease;
}

.hero-dot-active {
  width: 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.panel {
  margin: 24rpx 32rpx 0;
  padding: 30rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 28rpx rgba(90, 60, 47, 0.08);
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #34231a;
}

.tag-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  background: #f0dfd1;
  color: #7b5d4c;
  font-size: 22rpx;
}

.description {
  display: block;
  margin-top: 24rpx;
  line-height: 1.9;
  color: #493327;
}

.message-entry {
  margin: 24rpx 32rpx 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.message-entry-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 20rpx rgba(90, 60, 47, 0.06);
  display: flex;
  align-items: center;
}

.message-entry-placeholder {
  color: #ab907f;
  font-size: 26rpx;
}

.message-entry-button {
  height: 84rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: #3f2a1f;
  color: #fff8f2;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 700;
}

.message-entry-links {
  margin: 12rpx 32rpx 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.message-entry-link,
.message-entry-divider {
  font-size: 24rpx;
  color: #8f7362;
}

.message-entry-link-muted {
  color: #ae9382;
}

.history-panel {
  margin-top: 20rpx;
}

.history-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #34231a;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9a7d6b;
  line-height: 1.7;
}

.reply-pill {
  padding: 10rpx 18rpx;
  border-radius: 999px;
  background: #3f2a1f;
  color: #fff3e8;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 18rpx rgba(63, 42, 31, 0.18);
}

.history-placeholder {
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #f8f1ea;
  color: #8e7362;
  line-height: 1.8;
}

.history-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.related-panel {
  margin-top: 20rpx;
}

.related-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.related-card {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #f8f1ea;
}

.related-cover,
.related-cover-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.related-cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eadccc;
  color: #8d7262;
  font-size: 22rpx;
}

.related-content {
  flex: 1;
  min-width: 0;
}

.related-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #34231a;
}

.related-tag-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.history-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(123, 93, 76, 0.12);
}

.history-item-replied {
  border-bottom-color: rgba(91, 58, 41, 0.18);
}

.history-meta,
.reply-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.history-time,
.reply-time {
  font-size: 22rpx;
  color: #8d7262;
}

.history-status {
  padding: 8rpx 18rpx;
  border-radius: 999px;
  font-size: 22rpx;
  font-weight: 700;
}

.history-status-pending {
  background: #f3e1d2;
  color: #80593f;
}

.history-status-read {
  background: #eee8df;
  color: #6f655d;
}

.history-status-replied {
  background: #3f2a1f;
  color: #fff7f0;
}

.history-content,
.reply-content {
  display: block;
  margin-top: 16rpx;
  line-height: 1.9;
  color: #493327;
}

.reply-card {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f8f1ea;
}

.reply-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #6c4a38;
}

.primary-button {
  background: #3f2a1f;
  color: #fff8f2;
}

.secondary-button {
  background: #ead7c5;
  color: #4a3022;
}

.error-card {
  text-align: center;
}

.skeleton {
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }

  50% {
    opacity: 1;
  }

  100% {
    opacity: 0.65;
  }
}
