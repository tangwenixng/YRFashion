.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background: linear-gradient(180deg, #fcf7f1 0%, #eee3d6 100%);
}

.hero {
  width: 100%;
  height: 720rpx;
  background: rgba(255, 255, 255, 0.65);
}

.hero-image,
.hero-placeholder {
  width: 100%;
  height: 100%;
}

.hero-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8f7463;
}

.panel {
  margin: 24rpx 32rpx 0;
  padding: 30rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 28rpx rgba(90, 60, 47, 0.08);
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #34231a;
}

.tag-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  background: #f0dfd1;
  color: #7b5d4c;
  font-size: 22rpx;
}

.description {
  display: block;
  margin-top: 24rpx;
  line-height: 1.9;
  color: #493327;
}

.action-bar {
  margin: 24rpx 32rpx 0;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.history-panel {
  margin-top: 20rpx;
}

.history-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #34231a;
}

.section-subtitle {
  font-size: 22rpx;
  color: #9a7d6b;
}

.history-placeholder {
  margin-top: 20rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #f7efe7;
  color: #8e7362;
  line-height: 1.8;
}

.history-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f8f1ea;
}

.history-meta,
.reply-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.history-time,
.reply-time {
  font-size: 22rpx;
  color: #8d7262;
}

.history-status {
  padding: 8rpx 18rpx;
  border-radius: 999px;
  background: #ead7c5;
  color: #5b3a29;
  font-size: 22rpx;
}

.history-content,
.reply-content {
  display: block;
  margin-top: 16rpx;
  line-height: 1.9;
  color: #493327;
}

.reply-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.82);
}

.reply-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #6c4a38;
}

.primary-button {
  background: #3f2a1f;
  color: #fff8f2;
}

.secondary-button {
  background: #ead7c5;
  color: #4a3022;
}

.error-card {
  text-align: center;
}

.skeleton {
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
