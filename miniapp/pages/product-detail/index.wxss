@import "../../styles/custom-nav.wxss";

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background: linear-gradient(180deg, #f4f3f1 0%, #ebe9e6 100%);
}

.hero-wrap {
  position: relative;
  background: #f4f2ef;
}

.hero {
  width: 100%;
  min-height: 720rpx;
  background: rgba(255, 255, 255, 0.82);
}

.hero-image,
.hero-placeholder {
  width: 100%;
  height: 100%;
}

.hero-image {
  background: #f4f2ef;
}

.hero-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #85807a;
}

.hero-dots {
  position: absolute;
  left: 50%;
  bottom: 24rpx;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(34, 24, 18, 0.22);
}

.hero-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.62);
  transition: all 0.2s ease;
}

.hero-dot-active {
  width: 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.panel {
  margin: 24rpx 32rpx 0;
  padding: 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 28rpx rgba(31, 28, 26, 0.08);
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1f1c1a;
}

.tag-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  background: #f1efec;
  color: #69645f;
  font-size: 22rpx;
}

.description {
  display: block;
  margin-top: 24rpx;
  line-height: 1.9;
  color: #37312d;
}

.message-sync {
  margin: 18rpx 32rpx 0;
  display: flex;
  justify-content: flex-end;
}

.message-sync-text {
  font-size: 22rpx;
  color: #9d9892;
}

.message-entry {
  margin: 12rpx 32rpx 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.message-entry-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 20rpx rgba(31, 28, 26, 0.06);
  display: flex;
  align-items: center;
}

.message-entry-placeholder {
  color: #a7a29b;
  font-size: 26rpx;
}

.message-entry-button {
  height: 84rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: #1f1c1a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 700;
}

.message-entry-links {
  margin: 20rpx 32rpx 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.message-entry-link,
.message-entry-divider {
  font-size: 24rpx;
  color: #85807a;
}

.message-entry-link-muted {
  color: #a7a29b;
}

.history-panel {
  margin-top: 20rpx;
}

.history-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f1c1a;
}

.section-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #8f857e;
  line-height: 1.6;
}

.history-placeholder {
  margin-top: 28rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #f5f4f1;
  color: #85807a;
  line-height: 1.8;
}

.history-list {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.related-panel {
  margin-top: 20rpx;
}

.related-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.related-card {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #f5f4f1;
}

.related-cover,
.related-cover-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.related-cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e5dfd9;
  color: #867c76;
  font-size: 22rpx;
}

.related-content {
  flex: 1;
  min-width: 0;
}

.related-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f1c1a;
}

.related-tag-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.history-item {
  padding: 24rpx;
  border-radius: 22rpx;
  background: rgba(248, 241, 234, 0.72);
  border: 1rpx solid rgba(98, 89, 83, 0.08);
}

.history-item-replied {
  background: rgba(252, 247, 242, 0.96);
  border-color: rgba(98, 89, 83, 0.12);
}

.history-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.history-time,
.reply-time {
  font-size: 20rpx;
  color: #867c76;
}

.history-status {
  font-size: 20rpx;
  font-weight: 600;
}

.history-status-pending {
  color: #7a7671;
}

.history-status-read {
  color: #76716c;
}

.history-status-replied {
  color: #5f5751;
}

.history-content,
.reply-content {
  display: block;
  margin-top: 14rpx;
  line-height: 1.9;
  color: #37312d;
}

.reply-card {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #f2f0ed;
  box-shadow: 0 8rpx 18rpx rgba(31, 28, 26, 0.05);
}

.reply-prefix {
  font-size: 24rpx;
  font-weight: 700;
  color: #5f5751;
}

.primary-button {
  background: #1f1c1a;
  color: #ffffff;
}

.secondary-button {
  background: #ead7c5;
  color: #23201d;
}

.error-card {
  text-align: center;
}

.skeleton {
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }

  50% {
    opacity: 1;
  }

  100% {
    opacity: 0.65;
  }
}
