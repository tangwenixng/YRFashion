.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background: linear-gradient(180deg, #fcf7f1 0%, #eee3d6 100%);
}

.hero {
  width: 100%;
  height: 720rpx;
  background: rgba(255, 255, 255, 0.65);
}

.hero-image,
.hero-placeholder {
  width: 100%;
  height: 100%;
}

.hero-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8f7463;
}

.panel {
  margin: 24rpx 32rpx 0;
  padding: 30rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 28rpx rgba(90, 60, 47, 0.08);
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #34231a;
}

.tag-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  background: #f0dfd1;
  color: #7b5d4c;
  font-size: 22rpx;
}

.description {
  display: block;
  margin-top: 24rpx;
  line-height: 1.9;
  color: #493327;
}

.action-bar {
  margin: 24rpx 32rpx 0;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.history-panel {
  margin-top: 20rpx;
}

.history-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #34231a;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9a7d6b;
  line-height: 1.7;
}

.reply-pill {
  padding: 10rpx 18rpx;
  border-radius: 999px;
  background: #3f2a1f;
  color: #fff3e8;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 18rpx rgba(63, 42, 31, 0.18);
}

.history-placeholder {
  margin-top: 20rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #f7efe7;
  color: #8e7362;
  line-height: 1.8;
}

.history-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.related-panel {
  margin-top: 20rpx;
}

.related-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.related-card {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #f8f1ea;
}

.related-cover,
.related-cover-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.related-cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eadccc;
  color: #8d7262;
  font-size: 22rpx;
}

.related-content {
  flex: 1;
  min-width: 0;
}

.related-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #34231a;
}

.related-tag-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.history-item {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f8f1ea;
  border: 2rpx solid rgba(123, 93, 76, 0.06);
}

.history-item-replied {
  background: linear-gradient(180deg, #fff8f2 0%, #f4eadf 100%);
  border-color: rgba(91, 58, 41, 0.2);
  box-shadow: 0 14rpx 24rpx rgba(91, 58, 41, 0.08);
}

.history-meta,
.reply-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.history-time,
.reply-time {
  font-size: 22rpx;
  color: #8d7262;
}

.history-status {
  padding: 8rpx 18rpx;
  border-radius: 999px;
  font-size: 22rpx;
  font-weight: 700;
}

.history-status-pending {
  background: #f3e1d2;
  color: #80593f;
}

.history-status-read {
  background: #eee8df;
  color: #6f655d;
}

.history-status-replied {
  background: #3f2a1f;
  color: #fff7f0;
}

.history-content,
.reply-content {
  display: block;
  margin-top: 16rpx;
  line-height: 1.9;
  color: #493327;
}

.reply-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  border-left: 8rpx solid #3f2a1f;
}

.reply-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #6c4a38;
}

.primary-button {
  background: #3f2a1f;
  color: #fff8f2;
}

.secondary-button {
  background: #ead7c5;
  color: #4a3022;
}

.error-card {
  text-align: center;
}

.skeleton {
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }

  50% {
    opacity: 1;
  }

  100% {
    opacity: 0.65;
  }
}
