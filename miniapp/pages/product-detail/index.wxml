<view class="page">
  <block wx:if="{{loading}}">
    <view class="hero skeleton"></view>
    <view class="panel skeleton"></view>
  </block>

  <block wx:elif="{{error}}">
    <view class="panel error-card">
      <text class="title">穿搭详情</text>
      <text class="description">{{error}}</text>
      <button class="primary-button" bindtap="reloadProduct">重新加载</button>
    </view>
  </block>

  <block wx:elif="{{product}}">
    <view class="hero-wrap">
      <swiper
        class="hero"
        style="height: {{heroHeight}}rpx;"
        current="{{heroCurrent}}"
        indicator-dots="{{false}}"
        autoplay="{{product.images.length > 1}}"
        circular="true"
        bindchange="handleHeroChange"
      >
        <block wx:for="{{product.images}}" wx:key="id">
          <swiper-item>
            <image
              class="hero-image"
              src="{{item.image_url}}"
              mode="aspectFit"
              data-image-url="{{item.image_url}}"
              bindtap="previewImage"
            ></image>
          </swiper-item>
        </block>
        <swiper-item wx:if="{{!product.images.length}}">
          <view class="hero-placeholder">暂无展示图片</view>
        </swiper-item>
      </swiper>

      <view wx:if="{{product.images.length > 1}}" class="hero-dots">
        <view
          wx:for="{{product.images}}"
          wx:key="id"
          class="hero-dot {{index === heroCurrent ? 'hero-dot-active' : ''}}"
        ></view>
      </view>
    </view>

    <view class="panel">
      <text class="title">{{product.name}}</text>
      <view class="tag-row">
        <text wx:for="{{product.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
      <text class="description">{{product.description || '这里会持续更新这套穿搭的更多介绍。'}}</text>
    </view>

    <view class="message-entry">
      <view class="message-entry-input" bindtap="handleConsult">
        <text class="message-entry-placeholder">说说你的想法，欢迎留言交流</text>
      </view>
      <view class="message-entry-button" bindtap="handleConsult">
        <text>留言</text>
      </view>
    </view>

    <view class="message-entry-links">
      <text class="message-entry-link" bindtap="goToMessageHistory">查看留言记录</text>
      <text class="message-entry-divider">·</text>
      <text class="message-entry-link message-entry-link-muted" bindtap="goToContact">联系我</text>
    </view>

    <view class="panel history-panel">
      <view class="history-header">
        <view>
          <text class="section-title">我的留言</text>
          <text class="section-subtitle">
            <block wx:if="{{hasMiniappSession}}">
              自动刷新已开启{{messagesLastUpdatedText ? ' · 最近同步 ' + messagesLastUpdatedText : ''}}
            </block>
            <block wx:else>提交成功后会显示在这里</block>
          </text>
        </view>
        <view wx:if="{{hasUnreadReplies}}" class="reply-pill">有回复</view>
      </view>

      <view wx:if="{{messagesLoading}}" class="history-placeholder">留言记录加载中...</view>
      <view wx:elif="{{messagesError}}" class="history-placeholder">{{messagesError}}</view>
      <view wx:elif="{{!hasMiniappSession}}" class="history-placeholder">提交留言后，可在这里查看自己的留言和回复。</view>
      <view wx:elif="{{!messages.length}}" class="history-placeholder">还没有留言，点击上方按钮开始交流。</view>
      <view wx:else class="history-list">
        <view wx:for="{{messages}}" wx:key="id" class="history-item {{item.status_tone === 'replied' ? 'history-item-replied' : ''}}">
          <view class="history-meta">
            <text class="history-time">{{item.created_at_text}}</text>
            <text class="history-status history-status-{{item.status_tone}}">{{item.status_label}}</text>
          </view>
          <text class="history-content">{{item.content}}</text>

          <view wx:if="{{item.reply_content}}" class="reply-card">
            <view class="reply-header">
              <text class="reply-title">我的回复</text>
              <text class="reply-time">{{item.reply_at_text}}</text>
            </view>
            <text class="reply-content">{{item.reply_content}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{product.related_products && product.related_products.length}}" class="panel related-panel">
      <view class="history-header">
        <view>
          <text class="section-title">更多分享</text>
          <text class="section-subtitle">继续看看同风格或同分类的穿搭内容</text>
        </view>
      </view>

      <view class="related-list">
        <view
          wx:for="{{product.related_products}}"
          wx:key="id"
          class="related-card"
          data-product-id="{{item.id}}"
          bindtap="goToRelatedDetail"
        >
          <image wx:if="{{item.cover_image_url}}" class="related-cover" src="{{item.cover_image_url}}" mode="aspectFill"></image>
          <view wx:else class="related-cover related-cover-placeholder">暂无封面</view>
          <view class="related-content">
            <text class="related-name">{{item.name}}</text>
            <view class="related-tag-row">
              <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
