.page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #fcf7f1 0%, #efe1d2 100%);
}

.hero {
  padding: 12rpx 4rpx 28rpx;
}

.eyebrow,
.summary-label {
  display: block;
  font-size: 22rpx;
  color: #9f7c66;
  letter-spacing: 0.1em;
}

.title {
  display: block;
  margin-top: 14rpx;
  font-size: 50rpx;
  font-weight: 700;
  color: #2e1d14;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #846957;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.summary-card,
.action-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 30rpx rgba(90, 60, 44, 0.08);
}

.summary-value {
  display: block;
  margin-top: 18rpx;
  font-size: 48rpx;
  font-weight: 700;
  color: #342118;
}

.action-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #301f16;
}

.action-desc {
  display: block;
  margin-top: 14rpx;
  color: #836856;
  line-height: 1.8;
}

.logout-button {
  margin-top: 36rpx;
  background: #2f2018;
  color: #fff8f2;
}
