.page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #fcf7f1 0%, #efe6dc 100%);
}

.page-header {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  color: #352219;
}

.subtitle,
.meta-text,
.empty-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #8c6d5c;
  line-height: 1.7;
}

.toolbar {
  margin-top: 20rpx;
}

.toolbar-main-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  line-height: 84rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.9);
}

.create-button,
.ghost-button,
.mini-button,
.search-input,
.sort-input {
  box-sizing: border-box;
}

.create-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex: 0 0 176rpx;
  height: 72rpx;
  margin: 0;
  border-radius: 999px;
  background: #3f2a1f;
  color: #fff8f2;
  padding: 0 18rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.create-icon {
  font-size: 28rpx;
  line-height: 1;
}

.ghost-button,
.mini-button.secondary {
  background: #ead7c5;
  color: #4a3022;
}

.mini-button.ghost {
  background: #fff6ee;
  color: #4a3022;
  border: 1rpx solid rgba(101, 71, 51, 0.15);
}

.action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
}

.ghost-button,
.mini-button {
  background: #3f2a1f;
  color: #fff8f2;
}

.status-scroll {
  margin-top: 20rpx;
  width: 100%;
  white-space: nowrap;
}

.status-tabs {
  display: inline-flex;
  gap: 16rpx;
}

.status-tab {
  padding: 12rpx 26rpx;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.8);
  color: #765d4d;
}

.status-tab.active {
  background: #39251c;
  color: #fff7f0;
}

.list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  overflow: hidden;
  box-shadow: 0 18rpx 28rpx rgba(90, 60, 47, 0.08);
}

.cover,
.cover-placeholder {
  width: 100%;
  height: 300rpx;
}

.cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0e2d5;
  color: #8f7463;
}

.content {
  padding: 24rpx;
}

.content-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.product-name {
  flex: 1;
  font-size: 34rpx;
  font-weight: 600;
  color: #37231a;
  line-height: 1.4;
  word-break: break-all;
}

.status-badge {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999px;
  font-size: 22rpx;
}

.status-published {
  background: #dcefdc;
  color: #2d6840;
}

.status-draft {
  background: #f4e2c8;
  color: #7c5626;
}

.status-archived {
  background: #ece6e0;
  color: #6a5a4b;
}

.tag-row {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  background: #f2dfd1;
  color: #7b5a49;
  font-size: 22rpx;
}

.sort-row {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 64rpx minmax(0, 1fr) 220rpx;
  align-items: center;
  gap: 16rpx;
}

.meta-label {
  color: #7f6657;
  font-size: 24rpx;
}

.sort-input {
  width: 100%;
  height: 76rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  line-height: 76rpx;
  border-radius: 20rpx;
  background: #f7efe7;
}

.action-row {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.mini-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  padding: 0 20rpx;
  height: 76rpx;
  border-radius: 999px;
  font-size: 26rpx;
  text-align: center;
  white-space: nowrap;
}

.sort-row .mini-button {
  padding: 0;
}

.empty-card {
  margin-top: 28rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #3d2a20;
}

.skeleton {
  height: 420rpx;
  margin-top: 24rpx;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
