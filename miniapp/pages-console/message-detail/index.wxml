<view class="page">
  <block wx:if="{{loading}}">
    <view class="card skeleton"></view>
    <view class="card skeleton"></view>
  </block>

  <block wx:elif="{{error}}">
    <view class="card empty-card">
      <text class="empty-title">{{error}}</text>
      <button class="secondary-button" bindtap="loadDetail">重新加载</button>
    </view>
  </block>

  <block wx:elif="{{message}}">
    <view class="card user-card">
      <view class="user-row">
        <image wx:if="{{message.miniapp_user_avatar_url}}" class="avatar" src="{{message.miniapp_user_avatar_url}}" mode="aspectFill"></image>
        <view wx:else class="avatar avatar-fallback">{{message.avatar_initial}}</view>

        <view class="user-meta">
          <text class="user-name">{{message.user_display}}</text>
          <text class="sub-text">相关展示：{{message.product_name}}</text>
          <text class="sub-text">提交时间：{{message.created_at_text}}</text>
        </view>
      </view>

      <view class="status-row">
        <text class="status-badge status-{{message.status}}">{{message.status_label}}</text>
        <button wx:if="{{message.status === 'unread'}}" class="mini-button" bindtap="markRead">标记已读</button>
        <button wx:else class="mini-button secondary" bindtap="markUnread">标记未读</button>
      </view>
    </view>

    <view class="card content-card">
      <text class="section-title">用户咨询内容</text>
      <text class="content-text">{{message.content}}</text>
    </view>

    <view class="card">
      <text class="section-title">回复内容</text>
      <textarea
        class="textarea"
        maxlength="1000"
        placeholder="请输入回复内容"
        value="{{replyContent}}"
        bindinput="handleReplyInput"
      ></textarea>
      <button class="primary-button" loading="{{saving}}" bindtap="submitReply">发送回复</button>

      <view wx:if="{{message.reply_content}}" class="reply-history">
        <text class="section-title">当前回复</text>
        <text class="content-text">{{message.reply_content}}</text>
        <text wx:if="{{message.reply_at_text}}" class="sub-text">回复时间：{{message.reply_at_text}}</text>
      </view>
    </view>
  </block>
</view>
