.page {
  min-height: 100vh;
  padding: 40rpx 32rpx;
  background: linear-gradient(180deg, #f9f1e8 0%, #eadbcc 100%);
}

.hero {
  padding: 32rpx 8rpx 40rpx;
}

.eyebrow,
.label {
  display: block;
  color: #9e7d66;
  font-size: 24rpx;
  letter-spacing: 0.12em;
}

.title {
  display: block;
  margin-top: 14rpx;
  font-size: 52rpx;
  font-weight: 700;
  color: #2d1d14;
}

.subtitle {
  display: block;
  margin-top: 16rpx;
  color: #826854;
  line-height: 1.8;
}

.panel {
  padding: 34rpx 30rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 20rpx 40rpx rgba(92, 63, 45, 0.1);
}

.field + .field {
  margin-top: 24rpx;
}

.input {
  margin-top: 14rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f6ede4;
  color: #2d1d14;
}

.primary-button {
  margin-top: 28rpx;
  background: #2f2018;
  color: #fff7f0;
}

.error-text {
  display: block;
  margin-top: 18rpx;
  color: #b64040;
  font-size: 24rpx;
}

.tips {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  color: #8a715d;
  font-size: 24rpx;
  line-height: 1.7;
}
