.page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #fbf5ef 0%, #efe2d4 100%);
}

.card {
  padding: 30rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 28rpx rgba(90, 60, 47, 0.08);
}

.field + .field {
  margin-top: 24rpx;
}

.label {
  display: block;
  color: #8d705e;
  font-size: 24rpx;
}

.input,
.picker,
.textarea {
  margin-top: 14rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f6ede4;
  color: #2f1f16;
}

.textarea {
  min-height: 220rpx;
  width: 100%;
  box-sizing: border-box;
}

.primary-button {
  margin-top: 28rpx;
  background: #2f2018;
  color: #fff8f2;
}

.skeleton {
  height: 620rpx;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
