<view class="page">
  <block wx:if="{{loading}}">
    <view class="card skeleton"></view>
    <view class="card skeleton"></view>
  </block>

  <block wx:elif="{{error}}">
    <view class="card empty-card">
      <text class="empty-title">{{error}}</text>
      <button class="secondary-button" bindtap="loadProduct">重新加载</button>
    </view>
  </block>

  <block wx:elif="{{product}}">
    <view class="hero">
      <text class="title">{{product.name}}</text>
      <text class="subtitle">共 {{product.images.length}} 张图片</text>
    </view>

    <view class="toolbar">
      <button class="primary-button" loading="{{uploading}}" bindtap="chooseImages">上传图片</button>
      <button class="secondary-button" loading="{{savingSort}}" bindtap="saveSorts">保存排序</button>
    </view>

    <block wx:if="{{product.images.length}}">
      <view class="list">
        <block wx:for="{{product.images}}" wx:key="id">
          <view class="card image-card">
            <image class="image" src="{{item.image_url}}" mode="aspectFill"></image>

            <view class="content">
              <view class="row">
                <text class="image-name">{{item.original_name}}</text>
                <text wx:if="{{item.is_cover}}" class="cover-badge">封面</text>
              </view>

              <view class="sort-row">
                <text class="meta-label">排序</text>
                <input
                  class="sort-input"
                  type="number"
                  value="{{item.sort_order}}"
                  data-image-id="{{item.id}}"
                  bindinput="handleSortInput"
                />
              </view>

              <view class="action-row">
                <button class="mini-button" data-image-id="{{item.id}}" bindtap="setCover">设为封面</button>
                <button class="mini-button danger" data-image-id="{{item.id}}" bindtap="removeImage">删除</button>
              </view>
            </view>
          </view>
        </block>
      </view>
    </block>

    <view wx:else class="card empty-card">
      <text class="empty-title">暂时还没有图片</text>
      <text class="empty-subtitle">先上传图片，再设置封面。</text>
    </view>
  </block>
</view>
