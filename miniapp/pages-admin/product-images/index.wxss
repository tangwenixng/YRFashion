.page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #fcf8f2 0%, #efe3d7 100%);
}

.hero {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #321f16;
}

.subtitle,
.empty-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #8b6f5d;
}

.toolbar {
  display: flex;
  gap: 16rpx;
}

.primary-button,
.secondary-button,
.mini-button {
  background: #2f2018;
  color: #fff8f2;
}

.secondary-button {
  background: #ead8c7;
  color: #4a3022;
}

.mini-button.danger {
  background: #f6e5e5;
  color: #a24747;
}

.list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  overflow: hidden;
  box-shadow: 0 18rpx 28rpx rgba(90, 60, 47, 0.08);
}

.image {
  width: 100%;
  height: 360rpx;
}

.content {
  padding: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.image-name {
  flex: 1;
  font-size: 28rpx;
  color: #36231a;
  word-break: break-all;
}

.cover-badge {
  padding: 8rpx 18rpx;
  border-radius: 999px;
  background: #ead8c7;
  color: #6d4a33;
  font-size: 22rpx;
}

.sort-row {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.meta-label {
  color: #846959;
  font-size: 24rpx;
}

.sort-input {
  flex: 1;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #f6ede4;
}

.action-row {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.empty-card {
  margin-top: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #3d2a20;
}

.skeleton {
  height: 420rpx;
  margin-top: 24rpx;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
