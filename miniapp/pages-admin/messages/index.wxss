.page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #fbf6f0 0%, #eee2d7 100%);
}

.status-scroll {
  width: 100%;
  white-space: nowrap;
}

.status-tabs {
  display: inline-flex;
  gap: 16rpx;
}

.status-tab {
  padding: 12rpx 26rpx;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.8);
  color: #765d4d;
}

.status-tab.active {
  background: #39251c;
  color: #fff7f0;
}

.list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 28rpx rgba(90, 60, 47, 0.08);
}

.message-card {
  padding: 24rpx;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar,
.avatar-fallback {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: #e9d8ca;
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6d4c36;
  font-weight: 700;
}

.user-meta {
  flex: 1;
  min-width: 0;
}

.user-name,
.product-name,
.content,
.reply-text,
.empty-title {
  display: block;
}

.user-name {
  color: #342219;
  font-weight: 600;
}

.user-time,
.empty-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #8a6f5d;
  font-size: 24rpx;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  font-size: 22rpx;
}

.status-unread {
  background: #f6e0cc;
  color: #8d5b25;
}

.status-read {
  background: #e7ecef;
  color: #58656d;
}

.status-replied {
  background: #dceddf;
  color: #2e6e43;
}

.product-name {
  margin-top: 18rpx;
  color: #6f584a;
}

.content {
  margin-top: 16rpx;
  color: #2d1d14;
  line-height: 1.8;
}

.reply-text {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #f8efe6;
  color: #6c4b38;
  line-height: 1.7;
}

.action-row {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.mini-button,
.secondary-button {
  background: #2f2018;
  color: #fff8f2;
}

.mini-button.secondary,
.secondary-button {
  background: #ead8c7;
  color: #4a3022;
}

.mini-button.ghost {
  background: #fff8f2;
  color: #4a3022;
  border: 1rpx solid rgba(101, 71, 51, 0.15);
}

.empty-card {
  margin-top: 26rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.skeleton {
  height: 320rpx;
  margin-top: 24rpx;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.65;
  }
}
