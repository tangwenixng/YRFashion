<view class="page">
  <view class="page-header">
    <text class="title">展示管理</text>
    <text class="subtitle">在手机上管理展示内容、状态与图片。</text>
  </view>

  <view class="toolbar">
    <input
      class="search-input"
      placeholder="搜索展示名称或分类"
      value="{{keyword}}"
      bindinput="handleKeywordInput"
    />
    <button class="create-button" bindtap="openCreate">新增展示</button>
  </view>

  <scroll-view class="status-scroll" scroll-x="true" enable-flex="true">
    <view class="status-tabs">
      <block wx:for="{{statusTabs}}" wx:key="value">
        <view
          class="status-tab {{statusFilter === item.value ? 'active' : ''}}"
          data-status="{{item.value}}"
          bindtap="switchStatus"
        >
          {{item.label}}
        </view>
      </block>
    </view>
  </scroll-view>

  <block wx:if="{{loading}}">
    <view class="card skeleton"></view>
    <view class="card skeleton"></view>
  </block>

  <block wx:elif="{{error && !items.length}}">
    <view class="card empty-card">
      <text class="empty-title">{{error}}</text>
      <button class="ghost-button" bindtap="loadProducts">重新加载</button>
    </view>
  </block>

  <block wx:elif="{{items.length}}">
    <view class="list">
      <block wx:for="{{items}}" wx:key="id">
        <view class="card product-card">
          <image wx:if="{{item.cover_image_url}}" class="cover" src="{{item.cover_image_url}}" mode="aspectFill"></image>
          <view wx:else class="cover cover-placeholder">暂无封面</view>

          <view class="content">
            <view class="content-header">
              <text class="product-name">{{item.name}}</text>
              <text class="status-badge status-{{item.status}}">{{item.status_label}}</text>
            </view>

            <text class="meta-text">分类：{{item.category_name || '未分类'}}</text>
            <text class="meta-text">图片数：{{item.images.length}}</text>

            <view wx:if="{{item.tags.length}}" class="tag-row">
              <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
            </view>

            <view class="sort-row">
              <text class="meta-label">排序</text>
              <input
                class="sort-input"
                type="number"
                value="{{item.sort_order}}"
                data-product-id="{{item.id}}"
                bindinput="handleSortInput"
              />
              <button class="mini-button" data-product-id="{{item.id}}" catchtap="saveSort">保存排序</button>
            </view>

            <view class="action-row">
              <button class="mini-button" data-product-id="{{item.id}}" catchtap="openEdit">编辑</button>
              <button class="mini-button secondary" data-product-id="{{item.id}}" catchtap="openImages">图片</button>
              <button class="mini-button ghost" data-product-id="{{item.id}}" catchtap="toggleStatus">
                {{item.status === 'published' ? '下架' : '发布'}}
              </button>
            </view>
          </view>
        </view>
      </block>
    </view>
  </block>

  <block wx:else>
    <view class="card empty-card">
      <text class="empty-title">暂时还没有展示内容</text>
      <text class="empty-subtitle">先新增展示，再上传对应图片。</text>
    </view>
  </block>
</view>
