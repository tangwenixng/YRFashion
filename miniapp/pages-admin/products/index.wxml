<view class="page">
  <view class="page-header">
    <text class="title">Product Management</text>
    <text class="subtitle">Create, edit and manage product images from mobile.</text>
  </view>

  <view class="toolbar">
    <input
      class="search-input"
      placeholder="Search by product or category"
      value="{{keyword}}"
      bindinput="handleKeywordInput"
    />
    <button class="create-button" bindtap="openCreate">New Product</button>
  </view>

  <scroll-view class="status-scroll" scroll-x="true" enable-flex="true">
    <view class="status-tabs">
      <block wx:for="{{statusTabs}}" wx:key="value">
        <view
          class="status-tab {{statusFilter === item.value ? 'active' : ''}}"
          data-status="{{item.value}}"
          bindtap="switchStatus"
        >
          {{item.label}}
        </view>
      </block>
    </view>
  </scroll-view>

  <block wx:if="{{loading}}">
    <view class="card skeleton"></view>
    <view class="card skeleton"></view>
  </block>

  <block wx:elif="{{error && !items.length}}">
    <view class="card empty-card">
      <text class="empty-title">{{error}}</text>
      <button class="ghost-button" bindtap="loadProducts">Reload</button>
    </view>
  </block>

  <block wx:elif="{{items.length}}">
    <view class="list">
      <block wx:for="{{items}}" wx:key="id">
        <view class="card product-card">
          <image wx:if="{{item.cover_image_url}}" class="cover" src="{{item.cover_image_url}}" mode="aspectFill"></image>
          <view wx:else class="cover cover-placeholder">No cover</view>

          <view class="content">
            <view class="content-header">
              <text class="product-name">{{item.name}}</text>
              <text class="status-badge status-{{item.status}}">{{item.status_label}}</text>
            </view>

            <text class="meta-text">Category: {{item.category_name || 'Uncategorized'}}</text>
            <text class="meta-text">Images: {{item.images.length}}</text>

            <view wx:if="{{item.tags.length}}" class="tag-row">
              <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
            </view>

            <view class="sort-row">
              <text class="meta-label">Sort</text>
              <input
                class="sort-input"
                type="number"
                value="{{item.sort_order}}"
                data-product-id="{{item.id}}"
                bindinput="handleSortInput"
              />
              <button class="mini-button" data-product-id="{{item.id}}" catchtap="saveSort">Save Sort</button>
            </view>

            <view class="action-row">
              <button class="mini-button" data-product-id="{{item.id}}" catchtap="openEdit">Edit</button>
              <button class="mini-button secondary" data-product-id="{{item.id}}" catchtap="openImages">Images</button>
              <button class="mini-button ghost" data-product-id="{{item.id}}" catchtap="toggleStatus">
                {{item.status === 'published' ? 'Unpublish' : 'Publish'}}
              </button>
            </view>
          </view>
        </view>
      </block>
    </view>
  </block>

  <block wx:else>
    <view class="card empty-card">
      <text class="empty-title">No products yet</text>
      <text class="empty-subtitle">Create a product first, then upload images.</text>
    </view>
  </block>
</view>
