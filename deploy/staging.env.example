# Docker Compose project name.
COMPOSE_PROJECT_NAME=yrfashion-staging

# Public images for the staging environment.
BACKEND_IMAGE=ghcr.io/tangwenixng/yrfashion-backend:staging
FRONTEND_IMAGE=ghcr.io/tangwenixng/yrfashion-frontend:staging

# Host ports on 172.26.100.175.
BACKEND_PORT=8001
FRONTEND_PORT=8081

# Public paths.
API_PREFIX=/api
ADMIN_ENTRY_PATH=/fashion-dev

# Security and bootstrap admin.
SECRET_KEY=change-me-to-a-strong-staging-secret
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-staging-admin-password
BOOTSTRAP_ADMIN_DISPLAY_NAME=Store Admin Staging

# WeChat miniapp credentials.
MINIAPP_APP_ID=
MINIAPP_APP_SECRET=

# Optional CORS settings. Keep empty when frontend and API are on the same origin.
CORS_ALLOW_ORIGINS=
