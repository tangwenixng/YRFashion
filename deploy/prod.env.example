# Docker Compose project name.
# COMPOSE_PROJECT_NAME 等价于 docker compose -p <name>
COMPOSE_PROJECT_NAME=yrfashion-prod

# Public images for the production environment.
BACKEND_IMAGE=ghcr.io/tangwenixng/yrfashion-backend:prod
FRONTEND_IMAGE=ghcr.io/tangwenixng/yrfashion-frontend:prod

# Host ports on 172.26.100.175.
BACKEND_PORT=8000
FRONTEND_PORT=8080

# Public paths.
API_PREFIX=/api
ADMIN_ENTRY_PATH=/fashion

# Security and bootstrap admin.
SECRET_KEY=change-me-to-a-strong-prod-secret
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-prod-admin-password
BOOTSTRAP_ADMIN_DISPLAY_NAME=Store Admin

# WeChat miniapp credentials.
MINIAPP_APP_ID=
MINIAPP_APP_SECRET=

# Optional CORS settings. Keep empty when frontend and API are on the same origin.
CORS_ALLOW_ORIGINS=
